# Database
DATABASE_URL=sqlite:///data/finance.db

# ── LLM (use Groq — free tier, 14,400 req/day) ──────────────────────────────
# Sign up at https://console.groq.com to get a free API key
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional — only needed for Whisper audio transcription)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_strong_random_secret_here

# OTP via Email (optional — if not set, OTP is printed to server console)
# Use Gmail: enable App Passwords at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ── Seed data ────────────────────────────────────────────────────────────────
# Set to true ONCE to wipe seed data, then remove the line
# CLEAR_SEED_DATA=true
